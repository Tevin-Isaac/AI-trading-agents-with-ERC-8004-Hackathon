{
  "name": "erc8004-kraken-agent-ts",
  "version": "1.0.0",
  "description": "TypeScript/Node.js implementation of ERC-8004 AI Trading Agent with Kraken CLI MCP Integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "clean": "rimraf dist",
    "examples": "ts-node examples/mcp_examples.ts",
    "agent": "ts-node src/agent.ts",
    "deploy": "hardhat run scripts/deploy.ts --network sepolia"
  },
  "keywords": [
    "erc8004",
    "ethereum",
    "ai",
    "trading",
    "kraken",
    "mcp",
    "typescript",
    "defi"
  ],
  "author": "ERC-8004 Hackathon Team",
  "license": "MIT",
  "dependencies": {
    "@ethersproject/contracts": "^5.7.0",
    "@ethersproject/providers": "^5.7.2",
    "@ethersproject/abi": "^5.7.0",
    "@ethersproject/wallet": "^5.7.0",
    "ethers": "^6.8.1",
    "axios": "^1.6.2",
    "ws": "^8.14.2",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "rxjs": "^7.8.1",
    "node-cron": "^3.0.3",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@types/lodash": "^4.14.202",
    "@types/node-cron": "^3.0.11",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jest": "^29.5.8",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "rimraf": "^5.0.5",
    "hardhat": "^2.19.4",
    "@nomicfoundation/hardhat-toolbox": "^4.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
