# ERC-8004 AI Trading Agent Environment Configuration

# Blockchain Network Configuration
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
PRIVATE_KEY=your_private_key_here
NETWORK_ID=11155111  # Sepolia testnet

# ERC-8004 Contract Addresses (to be deployed)
IDENTITY_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
VALIDATION_REGISTRY_ADDRESS=
TRADING_AGENT_ADDRESS=

# Kraken CLI Configuration (Recommended)
# Install Kraken CLI: https://github.com/krakenfx/kraken-cli
KRAKEN_CLI_PATH=kraken  # Assumes kraken-cli is in PATH
KRAKEN_MCP_SERVICES=market,account,paper  # Safe services only
KRAKEN_ALLOW_DANGEROUS=false  # Set to true only for production with proper risk management

# Legacy Kraken API (if not using MCP)
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret
KRAKEN_SANDBOX=true

# Agent Configuration
AGENT_ID=hackathon_agent_001
AGENT_NAME=ERC-8004 Trading Bot
MAX_POSITION_SIZE=0.1  # 10% max position size
RISK_LEVEL=medium  # low, medium, high
CONFIDENCE_THRESHOLD=0.75

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/trading_agent.log

# Security Configuration
ENABLE_ERC8004_VALIDATION=true
REPUTATION_THRESHOLD=70
AUDIT_LOGGING=true

# Development Configuration
DEBUG=false
PAPER_TRADING_ONLY=true  # Keep true for hackathon demos
